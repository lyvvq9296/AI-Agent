    "@langchain/langgraph-checkpoint": "^1.0.1",
    "@langchain/tavily": "^1.2.0",
    "dotenv": "^17.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@langchain/langgraph-cli": "^1.1.17",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
